# ==============================================
# LLM Twin - Portfolio Project Configuration
# ==============================================

# --- MOCKING (Set individually or use defaults) ---
# Set to 'true' to run without incurring any AWS/API costs.
MOCK_LLM=true 
SKIP_TRAINING=true

# --- Required for RAG Functionality (if MOCK_LLM=false) ---

# OpenAI Config (Used for Embeddings/Reranking if not mocked)
OPENAI_MODEL_ID=gpt-4o-mini
OPENAI_API_KEY=your_openai_api_key_here

# Huggingface Config (For loading tokenizers)
HUGGINGFACE_ACCESS_TOKEN=your_hf_token_here

# --- Optional / Production MLOps Settings ---

# Comet ML (Experiment Tracking)
COMET_API_KEY=

# MongoDB (Data Warehouse)
DATABASE_HOST="mongodb://llm_engineering:llm_engineering@127.0.0.1:27017"

# Qdrant (Vector Database)
USE_QDRANT_CLOUD=false
QDRANT_CLOUD_URL=
QDRANT_APIKEY=

# AWS Config (Only if you want to deploy to cloud)
AWS_ARN_ROLE=
AWS_REGION=eu-central-1
AWS_ACCESS_KEY=
AWS_SECRET_KEY=

MOCK_LLM=true
QDRANT_DATABASE_PORT=6335

USE_OLLAMA=true
OLLAMA_MODEL_ID=llama3.2:3b
# OLLAMA_MODEL_ID=llama3:8b-instruct-q4_K_M